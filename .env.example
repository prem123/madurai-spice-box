# ---- Admin panel login ----
# The single password used to sign in at /admin/login
ADMIN_PASSWORD=change-this-password
# A random secret used to sign the admin session cookie (any long random string)
ADMIN_SECRET=replace-with-a-long-random-string

# ---- Production storage (Vercel) ----
# When these are set, products are stored in Vercel KV (Upstash Redis) and
# images are uploaded to Vercel Blob. If they are NOT set, the app falls back
# to a local JSON file (.data/products.json) and saves images to /public.
#
# Connect a Redis (KV) store + Blob store in the Vercel dashboard and these
# variables are added automatically. For local dev you can leave them blank.
KV_REST_API_URL=
KV_REST_API_TOKEN=
BLOB_READ_WRITE_TOKEN=
